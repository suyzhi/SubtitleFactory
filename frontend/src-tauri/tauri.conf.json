{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "字幕工厂",
  "version": "0.3.1",
  "identifier": "com.subtitlefactory.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "hiddenTitle": true,
        "titleBarStyle": "Transparent",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000; media-src 'self' http://127.0.0.1:8000; style-src 'self' 'unsafe-inline'; img-src 'self' data: http://127.0.0.1:8000 https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": [
      "backend-runtime"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false,
      "minimumSystemVersion": "12.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
