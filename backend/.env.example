# Optional defaults. AI settings can also be configured inside the App.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
WHISPER_MODEL=small

# Browser-only development server. Tauri generates a random token per launch.
# SUBTITLE_FACTORY_API_TOKEN=subtitle-factory-local-development

